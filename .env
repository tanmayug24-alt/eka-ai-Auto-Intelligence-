# PostgreSQL Database Configuration
DATABASE_URL=sqlite:///./eka_ai.db
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=20

# Application Settings
SECRET_KEY=development-secret-key-change-in-production-12345678901234567890
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production-12345678901234567890
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Environment
ENVIRONMENT=development
DEBUG=true

# AI Configuration
GEMINI_API_KEY=test-key-only-for-development
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.4
LLM_TOP_P=0.9
LLM_MAX_TOKENS=1024

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=test@example.com
SMTP_PASSWORD=test-password

# Redis Configuration
REDIS_URL=redis://localhost:6379
CACHE_EXPIRE_SECONDS=3600

# mTLS Configuration
MTLS_CERT_PATH=/tmp/mtls.crt
MTLS_KEY_PATH=/tmp/mtls.key
MTLS_CERT_ROTATION_HOURS=24

# Payment Gateway
RAZORPAY_KEY_ID=test-key
RAZORPAY_KEY_SECRET=test-secret

# File Storage
S3_BUCKET=eka-ai-bucket
S3_ACCESS_KEY=test-access
S3_SECRET_KEY=test-secret

# Observability
OTEL_ENABLED=true
PROMETHEUS_ENABLED=true

# Logging
LOG_LEVEL=INFO
